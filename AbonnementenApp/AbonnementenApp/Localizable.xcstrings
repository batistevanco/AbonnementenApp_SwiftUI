    },
    "Beheer hier je account- en betalingsgegevens per abonnement." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manage your account- en payment details for each subscription"
          }
        }
      }
    },
    "Bekijk privacy policy" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watch privacy policy"
          }
        }
      }
    },
    "Bepaal zelf wanneer items in **Binnenkort te betalen** verschijnen. In **Instellingen → Meldingen** kies je **1, 2, 3 of 4 weken**. De app toont dan alle abonnementen waarvan de vervaldatum binnen dat venster valt." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decide yourself when items appear in **Due Soon**. In **Settings → Notifications** you can choose **1, 2, 3 or 4 weeks**. The app will then show all subscriptions with a due date within that window."
          }
        }
      }
    },
    "Betaald" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paid"
          }
        }
      }
    },
